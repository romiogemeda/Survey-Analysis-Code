# =============================================================
# Survey Analysis Engine — Environment Variables
# =============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================

# API Keys — Required for LLM features (get yours at https://openrouter.ai/)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# LLM Configuration — Required (no defaults; server will not start without these)
# Prefix models with 'openrouter/' for litellm to route through OpenRouter
LLM_DEFAULT_MODEL=openrouter/openai/gpt-4o
LLM_FALLBACK_MODEL=openrouter/openai/gpt-4o

# Database — PostgreSQL connection string
# Default works with the Docker Compose setup
DB_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/survey_analysis

# Redis — Used for caching and as Celery broker
# Default works with the Docker Compose setup
REDIS_URL=redis://localhost:6379/0
